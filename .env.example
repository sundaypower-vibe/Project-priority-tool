# Notion API Integration
# 1. Go to https://www.notion.so/my-integrations and create a new integration
# 2. Copy the Internal Integration Secret below
NOTION_API_KEY=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 2. Share your "Solar projects" database with the integration
# 3. Copy the database ID from the URL:
#    https://www.notion.so/{workspace}/{DATABASE_ID}?v=...
NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Comma-separated list of names for the Responsible dropdown
RESPONSIBLE_NAMES=Alice,Bob,Charlie,David,Emma,Fossnes
